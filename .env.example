# ─── Supabase ───────────────────────────────────────────────────────────
# Project URL (Dashboard → Settings → API)
SUPABASE_URL=https://<project-ref>.supabase.co
# service_role key para o backend (Dashboard → Settings → API → service_role)
SUPABASE_KEY=eyJ...

# ─── HubSpot (plug-and-play — só será usado quando as stubs forem ligadas) ──
# Private App token com escopos: hubdb, crm.objects.contacts, crm.objects.companies, crm.objects.deals
HUBSPOT_PRIVATE_APP_TOKEN=

# ─── CORS ───────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5500

# ─── Logging ────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
